#lang racket

(require "tokenizer.rkt"
         "parser.rkt")

(define simple-source
  "create_room {
     name: \"cave\"
     description: \"dark and damp\"
     exits: [north, south]
     details: {
       size: \"small\"
       light: \"none\"
     }
   }")

;; Step 1: see the raw parse tree
(define raw (parse (make-tokenizer simple-source)))
(displayln "=== RAW PARSE TREE ===")
(pretty-print (syntax->datum raw))

;; Step 2: see the interpreted result
(displayln "\n=== INTERPRETED TREE ===")
(pretty-print (interpret-tree raw))